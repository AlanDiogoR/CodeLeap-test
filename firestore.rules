rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidPostCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly([
        'authorId', 'authorDisplayName', 'title', 'content',
        'imageUrl', 'createdAt', 'likesCount', 'commentsCount'
      ])
      && data.authorId is string
      && data.authorDisplayName is string
      && data.title is string
      && data.content is string
      && data.authorId == request.auth.uid
      && data.likesCount == 0
      && data.commentsCount == 0;
    }

    function isPostOwner() {
      return resource.data.authorId == request.auth.uid;
    }

    function isValidPostUpdate() {
      let data = request.resource.data;
      return data.authorId == resource.data.authorId
      && data.authorDisplayName == resource.data.authorDisplayName
      && data.title is string
      && data.content is string
      && data.likesCount == resource.data.likesCount
      && data.commentsCount == resource.data.commentsCount;
    }

    function isValidCommentCreate() {
      let data = request.resource.data;
      return data.keys().hasOnly(['author', 'authorId', 'text', 'createdAt'])
      && data.author is string
      && data.text is string
      && data.authorId == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPostCreate();
      allow update: if isAuthenticated() && isPostOwner() && isValidPostUpdate();
      allow delete: if isAuthenticated() && isPostOwner();

      match /likes/{likeId} {
        allow read: if true;
        allow create: if isAuthenticated()
          && likeId == request.auth.uid
          && request.resource.data.keys().hasOnly(['userId'])
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && likeId == request.auth.uid;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidCommentCreate();
      }
    }
  }
}
